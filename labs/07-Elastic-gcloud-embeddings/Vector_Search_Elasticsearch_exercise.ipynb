    "   ],\n",
    "   \"source\": [\n",
    "    \"# convert the field transcript_embedding to a list of floats (currently a string)\\n\",\n",
    "    \"def convert_embedding_to_list(embedding_str):\\n\",\n",
    "    \"    # Remove the brackets and split by comma\\n\",\n",
    "    \"    embedding_list = embedding_str.strip('[]').split(',')\\n\",\n",
    "    \"    # Convert each element to float and return as a list\\n\",\n",
    "    \"    return [float(x) for x in embedding_list]\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Function to fetch and process data from Elasticsearch\\n\",\n",
    "    \"def fetch_and_process_data(index_name):\\n\",\n",
    "    \"    # Fetch data from Elasticsearch\\n\",\n",
    "    \"    response = client.search(\\n\",\n",
    "    \"        index=index_name,\\n\",\n",
    "    \"        body={\\n\",\n",
    "    \"            \\\"query\\\": {\\n\",\n",
    "    \"                \\\"match_all\\\": {}\\n\",\n",
    "    \"            },\\n\",\n",
    "    \"            \\\"_source\\\": [\\\"transcript_embedding\\\"]\\n\",\n",
    "    \"        },\\n\",\n",
    "    \"        size=10000  # Adjust the size as needed\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Extract the transcript_embedding field from the response\\n\",\n",
    "    \"    embeddings = []\\n\",\n",
    "    \"    for hit in response['hits']['hits']:\\n\",\n",
    "    \"        if 'transcript_embedding' in hit['_source']:\\n\",\n",
    "    \"            embedding_str = hit['_source']['transcript_embedding']\\n\",\n",
    "    \"            embedding_list = convert_embedding_to_list(embedding_str)\\n\",\n",
    "    \"            embeddings.append(embedding_list)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return embeddings\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Fetch and process data\\n\",\n",
    "    \"embeddings = fetch_and_process_data(ELASTICSEARCH_INDEX_NAME)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Function to update the document in Elasticsearch\\n\",\n",
    "    \"def update_document(index_name, doc_id, normalized_embedding):\\n\",\n",
    "    \"    # Update the document in Elasticsearch\\n\",\n",
    "    \"    client.update(\\n\",\n",
    "    \"        index=index_name,\\n\",\n",
    "    \"        id=doc_id,\\n\",\n",
    "    \"        body={\\n\",\n",
    "    \"            \\\"doc\\\": {\\n\",\n",
    "    \"                \\\"dense_vector_embedding\\\": normalized_embedding\\n\",\n",
    "    \"            }\\n\",\n",
    "    \"        }\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"# Update the documents in Elasticsearch\\n\",\n",
    "    \"for i, hit in enumerate(client.search(\\n\",\n",
    "    \"        index=ELASTICSEARCH_INDEX_NAME,\\n\",\n",
    "    \"        body={\\n\",\n",
    "    \"            \\\"query\\\": {\\n\",\n",
    "    \"                \\\"match_all\\\": {}\\n\",\n",
    "    \"            },\\n\",\n",
    "    \"            \\\"_source\\\": [\\\"_id\\\"]\\n\",\n",
    "    \"        },\\n\",\n",
    "    \"        size=10000  # Adjust the size as needed\\n\",\n",
    "    \"    )['hits']['hits']):\\n\",\n",
    "    \"    doc_id = hit['_id']\\n\",\n",
    "    \"    embedding = embeddings[i]\\n\",\n",
    "    \"    update_document(ELASTICSEARCH_INDEX_NAME, doc_id, embedding)\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"7dfc5407\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"### **3. Performing a kNN Search**\\n\",\n",
    "    \"We will now send a request to Elasticsearch to find similar items using the vector representation.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"66d344e4\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"You can also try a query in a different language (e.g. in english)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
