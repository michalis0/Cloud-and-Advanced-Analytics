    "   \"source\": [\n",
    "    \"# Function to perform vector search\\n\",\n",
    "    \"def vector_search(query):\\n\",\n",
    "    \"    query_vector = generate_query_vector(query)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Search request body\\n\",\n",
    "    \"    body = {\\n\",\n",
    "    \"        \\\"_source\\\": [\\\"title\\\", \\\"video_id\\\"],\\n\",\n",
    "    \"        \\\"query\\\": {\\n\",\n",
    "    \"            \\\"knn\\\": {\\n\",\n",
    "    \"                \\\"field\\\": \\\"dense_vector_embedding\\\",  # Ensure this matches the correct field in your index mapping\\n\",\n",
    "    \"                \\\"query_vector\\\": query_vector,\\n\",\n",
    "    \"                \\\"k\\\": 20,  \\n\",\n",
    "    \"                \\\"num_candidates\\\": 50  \\n\",\n",
    "    \"            }\\n\",\n",
    "    \"        },\\n\",\n",
    "    \"        \\\"size\\\": 40\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Execute search\\n\",\n",
    "    \"    response = client.search(index=ELASTICSEARCH_INDEX_NAME, body=body)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Process results\\n\",\n",
    "    \"    search_results = {}\\n\",\n",
    "    \"    for hit in response[\\\"hits\\\"][\\\"hits\\\"]:\\n\",\n",
    "    \"        source = hit.get(\\\"_source\\\", {})\\n\",\n",
    "    \"        score = hit.get(\\\"_score\\\", 0)\\n\",\n",
    "    \"        video_id = source.get(\\\"video_id\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Deduplicate by video_id, keeping highest-score entry\\n\",\n",
    "    \"        if video_id not in search_results or search_results[video_id][\\\"similarity_score\\\"] < score:\\n\",\n",
    "    \"            search_results[video_id] = {\\n\",\n",
    "    \"                \\\"title\\\": source.get(\\\"title\\\"),\\n\",\n",
    "    \"                \\\"video_id\\\": video_id,\\n\",\n",
    "    \"                \\\"similarity_score\\\": score\\n\",\n",
    "    \"            }\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return list(search_results.values())\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Example usage\\n\",\n",
    "    \"query_example = \\\"Les bases de la grammaire française\\\"\\n\",\n",
    "    \"results = vector_search(query_example)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Display first 5 results\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"df_results = pd.DataFrame(results)\\n\",\n",
    "    \"display(df_results.head())\"\n",
